# MediSync Frontend — Environment Variables
# Copy to .env.local for local development. Set as Vercel env vars for production.
# Never commit .env.local — it is gitignored.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API → Project URL / anon public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Backend URL ───────────────────────────────────────────────────────────────
# Local dev: http://localhost:8000
# Production: your Railway deployment URL, e.g. https://medisync-api.up.railway.app
# If unset, next.config.js defaults to http://localhost:8000 for local dev.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── TTS (server-side only — do NOT add NEXT_PUBLIC_ prefix) ──────────────────
# Used only in the /api/tts Next.js route handler (never sent to the browser).
# Sarvam AI key: https://dashboard.sarvam.ai → API Keys
# Leave blank to disable TTS — the Listen button returns 503 gracefully.
SARVAM_API_KEY=
