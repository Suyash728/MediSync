# MediSync Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ─── Supabase (backend) ───────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — NEVER expose publicly
SUPABASE_ANON_KEY=eyJ...      # anon/public key

# ─── LLM (server-side only) ───────────────────────────────────────────────────
# Groq: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...
# Gemini: https://aistudio.google.com → Get API key
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ─── NER model ────────────────────────────────────────────────────────────────
# Set to false on Railway free tier (0.5 GB RAM — BioBERT alone is ~400 MB).
# LLM extraction still handles structured data; BioBERT is a secondary signal.
# Set to true if you have >= 2 GB RAM available.
USE_LOCAL_NER=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins. Add your Vercel URL after deployment.
# Example: ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── App config ───────────────────────────────────────────────────────────────
# "development" enables /docs (Swagger UI). Set to "production" on Railway.
ENVIRONMENT=development

# ─── TTS (optional) ───────────────────────────────────────────────────────────
# Sarvam AI key for the /api/tts route (11 Indian languages).
# Leave blank to disable TTS — button returns 503 gracefully.
SARVAM_API_KEY=

# ─── ABDM (optional) ──────────────────────────────────────────────────────────
# App degrades gracefully without these — ABHA verification returns 503.
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://sandbox.abdm.gov.in
