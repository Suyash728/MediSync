# ─── Supabase (backend) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # NEVER expose to frontend
SUPABASE_ANON_KEY=your-anon-key

# ─── LLM (server-side only) ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...                        # Optional fallback

# ─── TTS (optional Phase 5) ───────────────────────────────────────────────────
# Sarvam AI Bulbul:v3 — 11 Indian languages.  Leave blank to disable TTS.
SARVAM_API_KEY=

# ─── ABDM (optional Phase 5) ──────────────────────────────────────────────────
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://sandbox.abdm.gov.in

# ─── App config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000"]
